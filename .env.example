# ══════════════════════════════════════════════════════════════════
#  DevOps Swarm — .env
#  Copy this file to .env, fill in the 3 required values below,
#  and you're ready to run in under 10 minutes.
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED FOR TESTING (get these first) ────────────────────────

# 1. Groq — FREE at https://console.groq.com
#    Sign up → API Keys → Create API Key
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# 2. E2B — FREE at https://e2b.dev
#    Sign up → Dashboard → API Keys → Copy
E2B_API_KEY=e2b_YOUR_E2B_KEY_HERE

# 3. GitHub Personal Access Token — FREE
#    github.com → Settings → Developer Settings → Personal Access Tokens
#    → Tokens (classic) → Generate new token (classic)
#    → Check: repo (all), workflow
#    → Copy the token
GITHUB_PAT=ghp_YOUR_GITHUB_PAT_HERE

# ── OPTIONAL (only needed for real GitHub webhook production flow) ─

# GitHub App ID (create at github.com/settings/apps/new)
GITHUB_APP_ID=

# GitHub App private key (paste full PEM, replace newlines with \n)
GITHUB_PRIVATE_KEY=

# Webhook secret (set in GitHub App settings)
GITHUB_WEBHOOK_SECRET=

# ── INFRASTRUCTURE (don't change these for local Docker dev) ──────

DATABASE_URL=postgresql+asyncpg://swarm:swarmpass@postgres:5432/devops_swarm
CORS_ORIGINS=http://localhost:3000
GROQ_MODEL=llama-3.3-70b-versatile
MAX_CORRECTION_ITERATIONS=3
